# Public hosts. Point all three DNS A/AAAA records to the VPS before deployment.
FRONTEND_HOST=useniti.xyz
API_HOST=api.useniti.xyz
TRAEFIK_HOST=traefik.useniti.xyz
LETSENCRYPT_EMAIL=ops@useniti.xyz
DOCKER_NETWORK_NAME=niti

# Replace every CHANGE_ME value before a production deployment.
POSTGRES_DB=niti
POSTGRES_USER=niti
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql+psycopg://niti:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/niti
POSTGRES_PORT=5432
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET

ACCESS_TOKEN_EXPIRE_MINUTES=10080
BACKEND_WORKERS=2

# Example login is admin / change-me. Generate a replacement with:
# htpasswd -nbB admin 'your-password'
# Keep this value single-quoted so Compose treats the $ characters literally.
TRAEFIK_DASHBOARD_AUTH_USERS='admin:$2y$05$fp4S6KUtP8vmR/ZK.etVSebXcaQl9hAmL/ueBtjPURzPj2RG.7Swe'
